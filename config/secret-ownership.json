{
  "schema_version": 1,
  "legacy_github_inventory": {
    "captured_on": "2026-07-10",
    "expected_name_count": 47,
    "owner": "platform/security",
    "review_due_on": "2026-08-15",
    "status": "legacy_mirror_remove_after_migration",
    "evidence": "GitHub issue #27 inventory comment"
  },
  "default_rule": {
    "canonical_store": "doppler",
    "owner": "platform/security",
    "rotation_days": 90,
    "action": "migrate_then_delete_github_mirror"
  },
  "classification_rules": [
    {
      "id": "signing-and-play-binary-material",
      "name_prefixes": ["KEYSTORE_", "KEY_", "PLAY_SERVICE_ACCOUNT_"],
      "canonical_store": "azure_secure_files_or_variable_group",
      "owner": "release/platform",
      "rotation_mode": "event_driven_and_incident",
      "action": "migrate_then_delete_github_mirror"
    },
    {
      "id": "doppler-bootstrap",
      "name_prefixes": ["DOPPLER_"],
      "canonical_store": "azure_variable_group",
      "owner": "release/platform",
      "rotation_days": 90,
      "action": "keep_only_bootstrap_token_secret; move identifiers to nonsecret variables"
    },
    {
      "id": "github-automation-identity",
      "name_prefixes": ["GH_"],
      "canonical_store": "azure_system_access_token_or_oidc",
      "owner": "platform/security",
      "rotation_mode": "revoke_before_removal",
      "action": "replace_long_lived_identity_then_delete"
    },
    {
      "id": "cloudflare-legacy-global-key",
      "name_prefixes": ["CLOUDFLARE_"],
      "canonical_store": "doppler_scoped_api_token",
      "owner": "platform/security",
      "rotation_days": 90,
      "action": "replace_global_key_with_scoped_token_then_delete"
    },
    {
      "id": "runtime-service-credentials",
      "name_prefixes": ["ADMOB_", "CF_", "FIREBASE_", "GOOGLE_", "SENTRY_", "VITE_"],
      "canonical_store": "doppler",
      "owner": "platform/security",
      "rotation_days": 90,
      "action": "migrate_then_delete_github_mirror"
    }
  ]
}
