  "pii_policy": {
    "forbidden_parameter_tokens": [
      "email",
      "phone",
      "address",
      "auth_token",
      "access_token",
      "refresh_token",
      "purchase_token",
      "advertising_id",
      "device_id",
      "latitude",
      "longitude"
    ],
    "runtime_dropped_parameters": [
      "error_message"
    ],
    "opaque_user_id_prefix": "anon_",
    "max_string_length": 100
  },
  "cardinality_policy": {
    "low": "Fewer than 50 values per 30 days.",
    "medium": "Fewer than 500 values per 30 days.",
    "high": "Not used as a default dashboard dimension; query only with bounded filters."
  }
}
