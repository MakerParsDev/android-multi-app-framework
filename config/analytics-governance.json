      "owner": "monetization"
    },
    {
      "prefix": "rewarded_",
      "owner": "monetization"
    },
    {
      "prefix": "history_unlock_",
      "owner": "monetization"
    },
    {
      "prefix": "purchase",
      "owner": "billing"
    },
    {
      "prefix": "subscription_",
      "owner": "billing"
    },
    {
      "prefix": "billing_",
      "owner": "billing"
    },
    {
      "prefix": "paywall_",
      "owner": "billing"
    },
    {
      "prefix": "audio_",
      "owner": "audio"
    },
    {
      "prefix": "content_",
      "owner": "content"
    },
    {
      "prefix": "verse_",
      "owner": "content"
    },
    {
      "prefix": "display_",
      "owner": "content"
    },
    {
      "prefix": "prayer_",
      "owner": "prayer-times"
    },
    {
      "prefix": "push_",
      "owner": "notifications"
    },
    {
      "prefix": "notification_",
      "owner": "notifications"
    },
    {
      "prefix": "notifications_",
      "owner": "notifications"
    },
    {
      "prefix": "consent_",
      "owner": "privacy"
    },
    {
      "prefix": "privacy_",
