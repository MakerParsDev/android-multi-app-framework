{
  "schema_version": 2,
  "ga4_property_id": "526790653",
  "retention_months": 14,
  "required_default_parameters": [
    "flavor_id",
    "app_version",
    "analytics_schema_version",
    "consent_state",
    "subscription_status"
  ],
  "custom_dimensions": [
    {
      "parameter_name": "flavor_id",
      "display_name": "Flavor ID",
      "scope": "EVENT",
      "cardinality": "low",
      "description": "Stable product flavor identifier shared by all Android streams."
    },
    {
      "parameter_name": "app_version",
      "display_name": "App Version",
      "scope": "EVENT",
      "cardinality": "medium",
      "description": "Application version name attached to every governed event."
    },
    {
      "parameter_name": "consent_state",
      "display_name": "Consent State",
      "scope": "EVENT",
      "cardinality": "low",
      "description": "Resolved analytics/ads consent lifecycle state."
    },
    {
      "parameter_name": "ad_format",
      "display_name": "Ad Format",
      "scope": "EVENT",
      "cardinality": "low",
      "description": "Banner, interstitial, rewarded, app-open, or native format."
    },
    {
      "parameter_name": "ad_placement",
      "display_name": "Ad Placement",
      "scope": "EVENT",
      "cardinality": "medium",
      "description": "Bounded AdPlacement enum value."
    },
    {
      "parameter_name": "content_id",
      "display_name": "Content ID",
      "scope": "EVENT",
      "cardinality": "high",
      "description": "Bounded application content identifier; never a user identifier."
    },
    {
      "parameter_name": "subscription_status",
      "display_name": "Subscription Status",
      "scope": "EVENT",
      "cardinality": "low",
      "description": "unknown, loading, active, inactive, or error."
    }
  ],
  "custom_metrics": [
    {
      "parameter_name": "ad_value",
      "display_name": "Ad Value",
      "scope": "EVENT",
      "measurement_unit": "STANDARD",
      "description": "Paid-event numeric value; currency is carried by the same event's currency parameter."
    },
    {
      "parameter_name": "audio_duration_ms",
      "display_name": "Audio Duration",
      "scope": "EVENT",
      "measurement_unit": "MILLISECONDS",
      "description": "Completed audio duration in milliseconds."
    },
    {
      "parameter_name": "load_latency_ms",
      "display_name": "Ad Load Latency",
      "scope": "EVENT",
      "measurement_unit": "MILLISECONDS",
      "description": "Ad request-to-fill latency in milliseconds."
    }
  ],
  "key_events": [
    "purchase",
    "content_play_complete",
    "audio_complete",
    "rewarded_watch_complete",
    "push_open"
  ],
  "retired_key_events": [
    "add_to_cart",
    "add_to_wishlist",
    "begin_checkout",
    "session_start",
    "view_item",
    "view_item_list",
    "view_search_results"
  ],
  "event_owner_rules": [
