{
  "name": "admin-notifications",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "inject:flavor-versions": "node scripts/inject-flavor-versions.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src test scripts vite.config.ts --max-warnings=0",
    "test": "vitest run",
    "verify": "npm run lint && npm test && npm run build && node scripts/verify-build-metadata.mjs",
    "predeploy": "npm run verify",
    "deploy": "node ../../scripts/ci/deploy_verified_side_project.mjs admin-notifications"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.14",
    "eslint": "^10.7.0",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.0.0"
  }
}
